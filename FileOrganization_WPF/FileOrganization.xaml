<Window x:Class="FileOrganization_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileOrganization_WPF"
        mc:Ignorable="d"
        Title="파일 자동 정리" Height="450" Width="700">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>
    <Grid HorizontalAlignment="Left" Width="800">
        <TextBlock HorizontalAlignment="Left" FontSize="14" FontWeight="Bold" Margin="61,68,0,0" TextWrapping="Wrap" Text="파일을 정리할 폴더를 선택하세요." VerticalAlignment="Top"/>
        <Button Content="폴더 찾기" HorizontalAlignment="Left" Margin="61,100,0,0" VerticalAlignment="Top" Click="SelectFolder_Click" Height="24" Width="72"/>
        <TextBlock x:Name="PathDisplay" HorizontalAlignment="Left" FontSize="12" Margin="140,104,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" />

        <TextBlock HorizontalAlignment="Left" FontSize="14" FontWeight="Bold" Margin="61,184,0,0" TextWrapping="Wrap" Text="파일을 정리할 기준을 선택하세요." VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" FontSize="14" Margin="61,209,0,0" TextWrapping="Wrap" Text="*파일명 언어의 경우, 파일명이 한글이면 Korea, 영어면 English로 분류됩니다." VerticalAlignment="Top"><Run Language="ko-kr"/></TextBlock>
        <RadioButton Name="ExtensionRadio" Content="확장자" HorizontalAlignment="Left" IsChecked = "True" Margin="111,252,0,0" VerticalAlignment="Top"/>
        <RadioButton Name="DateRadio" Content="날짜(YYYY-MM)" HorizontalAlignment="Left" Margin="284,252,0,0" VerticalAlignment="Top"/>
        <RadioButton Name="LanguageRadio" Content="파일명 언어" HorizontalAlignment="Left" Margin="496,252,0,0" VerticalAlignment="Top"/>

        <Button Content="정리하기" HorizontalAlignment="Left" Margin="306,332,0,0" VerticalAlignment="Top" Click="OrganizeButton_Click" Height="32" Width="78"/>
    </Grid>
</Window>
